{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m evaluation.ragas_eval:*)",
      "Bash(docker-compose:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(pip install:*)",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(.env)",
      "Read(.env.production)",
      "Bash(cdk deploy:*)"
    ]
  },
  "env": {
    "PYTHONPATH": "."
  }
}
