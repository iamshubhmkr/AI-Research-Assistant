# ─────────────────────────────────────────────────────────────
# Example environment file. Copy to `.env` and fill in real values.
#   cp .env.example .env
# All settings have defaults in config.py; only override what you need.
# NEVER commit your real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────
# "bedrock" (primary, bills to AWS) or "anthropic" (direct API fallback)
LLM_PROVIDER=bedrock
ENABLE_PROVIDER_FALLBACK=false

# ── Anthropic (only needed if LLM_PROVIDER=anthropic or fallback enabled) ──
ANTHROPIC_API_KEY=

# ── AWS / Bedrock ────────────────────────────────────────────
AWS_REGION=us-east-1
# Use either a named profile OR standard AWS credentials in your shell/role.
AWS_PROFILE=
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are read by the AWS SDK if set.
S3_BUCKET=research-assistant-papers

# ── Redis (semantic + LLM cache) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── PostgreSQL (HITL checkpoint store) ───────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_URL=postgresql://user:pass@localhost:5432/research_db

# ── DynamoDB (session persistence) ───────────────────────────
ENABLE_DYNAMO=false
DYNAMO_SESSIONS_TABLE=research-sessions

# ── LangSmith tracing (optional) ─────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=research-assistant
LANGCHAIN_API_KEY=

# ── Retrieval / deployment ───────────────────────────────────
RETRIEVAL_MODE=hybrid
DEPLOYMENT_ENV=development
LOG_LEVEL=INFO
